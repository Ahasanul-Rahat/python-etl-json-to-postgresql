# ==================================================================
# Python Environment Setup for ETL, Data Analysis & Visualization
# Stack: PostgreSQL, CSV, JSON, Excel, pandas, numpy, matplotlib, API
# Windows | VS Code
# ==================================================================

# Step 1: Verify Python installation
python --version

# Step 2: Create project folder structure
mkdir D:\python-projects\etl-project
cd D:\python-projects\etl-project
mkdir data
mkdir data\raw
mkdir data\processed
mkdir notebooks
mkdir scripts
code .

# Step 3: Create virtual environment
python -m venv venv

# Step 4: Activate virtual environment
venv\Scripts\activate

# ==================================================================
# VS Code Extensions (install manually via Extensions panel - Ctrl+Shift+X)
# ==================================================================
# - Python (by Microsoft)
# - Jupyter (by Microsoft)
# - Pylance (auto-installs)
# - Rainbow CSV (optional, helps view CSV files with colored columns)

# ==================================================================
# Step 5: Install all required libraries
# ==================================================================

# Core data handling
pip install pandas numpy

# Excel support (read/write .xlsx)
pip install openpyxl xlrd

# PostgreSQL connection
pip install psycopg2-binary sqlalchemy

# API requests
pip install requests

# Visualization
pip install matplotlib seaborn plotly

# Jupyter support
pip install jupyter ipykernel

# Environment variable management (for DB credentials, API keys - security best practice)
pip install python-dotenv

# ==================================================================
# Step 6: Select Interpreter in VS Code (manual step)
# ==================================================================
# Ctrl+Shift+P -> "Python: Select Interpreter"
# Choose: .\venv\Scripts\python.exe

# ==================================================================
# Step 7: Create .env file for credentials (NEVER hardcode passwords)
# ==================================================================
# File: .env
# ---------------------------------------------
# DB_HOST=localhost
# DB_PORT=5433
# DB_NAME=your_database
# DB_USER=postgres
# DB_PASSWORD=your_password
# API_KEY=your_api_key_here
# ---------------------------------------------

# ==================================================================
# Step 8: Create requirements.txt (for reproducibility / GitHub sharing)
# ==================================================================
pip freeze > requirements.txt

# To reinstall later on any machine:
# pip install -r requirements.txt

